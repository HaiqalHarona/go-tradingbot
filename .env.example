# ==========================================
# Alpaca Trade API Credentials
# ==========================================
# API key identifier provided by Alpaca
APCA_API_KEY_ID=your_alpaca_key_id_here

# Secret key corresponding to the API key ID
APCA_API_SECRET_KEY=your_alpaca_secret_key_here

# Base URL for Alpaca Trade API (Paper Trading: https://paper-api.alpaca.markets)
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# ==========================================
# Trading Bot & Risk Management Rules
# ==========================================
# Comma-separated list of stock tickers to monitor in the trading loop
STOCK_POOL=AAPL,HLAL,NVDA,SPUS,TSLA

# Fraction of total account equity allocated per trade (e.g., 0.02 = 2%)
EQUITY_ALLOCATION_PCT=0.02

# Stop-loss percentage for order bracket leg (e.g., 0.015 = 1.5% below entry price)
STOP_LOSS_PCT=0.015

# Take-profit percentage for order bracket leg (e.g., 0.030 = 3.0% above entry price)
TAKE_PROFIT_PCT=0.030

# Maximum number of combined active open positions and pending open orders allowed
MAX_OPEN_POSITIONS=4

# Discord Webhook URL for instant order notifications (Optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
